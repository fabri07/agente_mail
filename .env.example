# Gmail API OAuth client credentials file path
GMAIL_CREDENTIALS_FILE=credentials.json

# OAuth token output path (generated after auth)
GMAIL_TOKEN_FILE=token.json

# SQLite database path
DB_PATH=db/gmail_agent.db

# Logs file path
LOG_FILE=logs/run.log

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Progress log interval (every N processed emails)
PROGRESS_EVERY=100

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Duración máxima de la sesión del agente en segundos (default: 3600 = 1 hora)
AGENT_SESSION_DURATION=1800

# Modelo Claude a usar
CLAUDE_MODEL=claude-opus-4-6
